generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  gestor
  editor
  leitor
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  role          Role
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  last_active_at DateTime @default(now())
  avatar_url     String?
  reset_token    String?
  reset_token_expires DateTime?

  task_assignees TaskAssignee[]
  spaces         Space[]      @relation("UserSpaces")
  member_of      SpaceMember[]
  notifications  Notification[]
  activities     TaskActivity[]
  companies      CompanyMember[]

  @@map("users")
}

model Space {
  id          String   @id @default(uuid())
  name        String
  description String?
  owner_id    String
  
  owner       User     @relation("UserSpaces", fields: [owner_id], references: [id])
  folders     Folder[]
  tags        Tag[]
  members     SpaceMember[]

  @@map("spaces")
}

model SpaceMember {
  id        String   @id @default(uuid())
  space_id  String
  user_id   String
  role      String   @default("editor")
  joined_at DateTime @default(now())

  space     Space    @relation(fields: [space_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([space_id, user_id])
  @@map("space_members")
}

model Folder {
  id          String   @id @default(uuid())
  space_id    String
  name        String
  description String?

  space       Space    @relation(fields: [space_id], references: [id], onDelete: Cascade)
  lists       List[]

  @@map("folders")
}

model List {
  id        String   @id @default(uuid())
  folder_id String
  name      String

  folder    Folder   @relation(fields: [folder_id], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@map("lists")
}

model Task {
  id          String    @id @default(uuid())
  list_id     String
  title       String
  description String?
  deadline    DateTime?
  status      String    
  priority    String?   @default("medium")
  estimated_hours Int?  @default(0)
  task_value  Decimal?  @db.Decimal(10, 2) @default(0)
  start_date  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  list        List      @relation(fields: [list_id], references: [id], onDelete: Cascade)
  assignees   TaskAssignee[]
  tags        TaskTag[]
  attachments Attachment[]
  activities  TaskActivity[]

  @@map("tasks")
}

model TaskAssignee {
  task_id String
  user_id String

  task    Task   @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([task_id, user_id])
  @@map("task_assignees")
}

model Tag {
  id       String    @id @default(uuid())
  space_id String?   
  name     String
  color    String

  space    Space?     @relation(fields: [space_id], references: [id])
  tasks    TaskTag[]

  @@map("tags")
}

model TaskTag {
  task_id String
  tag_id  String

  task    Task @relation(fields: [task_id], references: [id], onDelete: Cascade)
  tag     Tag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([task_id, tag_id])
  @@map("task_tags")
}

model Attachment {
  id          String   @id @default(uuid())
  task_id     String
  file_url    String
  file_name   String
  file_type   String
  uploaded_by String? 

  task        Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  title      String
  message    String
  read       Boolean  @default(false)
  type       String   @default("info") // 'assignment', 'mention', 'info'
  link       String?  // URL to redirect (e.g., /metrics)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model TaskActivity {
  id          String   @id @default(uuid())
  task_id     String
  user_id     String
  type        String   // 'system' | 'comment'
  content     String   // The message or log description
  created_at  DateTime @default(now())

  task        Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("task_activities")
}

model Company {
  id              String          @id @default(uuid())
  name            String
  status          String          @default("active") // active, inactive
  niche           String?
  investment      Decimal?        @db.Decimal(10, 2)
  partnership_type String?        @map("partnership_type")
  start_date      DateTime?       @map("start_date")
  contract_due    DateTime?       @map("contract_due")
  contract_value  Decimal?        @map("contract_value") @db.Decimal(10, 2)
  content_quota   Int?            @map("content_quota")
  created_at      DateTime        @default(now()) @map("created_at")
  updated_at      DateTime        @updatedAt @map("updated_at")

  members         CompanyMember[]

  @@map("companies")
}



model CompanyMember {
  id          String   @id @default(uuid())
  company_id  String   @map("company_id")
  user_id     String   @map("user_id")
  role        String   // Filmmaker, Editor, Designer, Marketing Consultant
  joined_at   DateTime @default(now()) @map("joined_at")

  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([company_id, user_id])
  @@map("company_members")
}
